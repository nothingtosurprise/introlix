# Backend & Frontend Local Build Dockerfile
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    MAKEFLAGS="-j1"

WORKDIR /app

# Install system dependencies (curl, git, compile dependencies and playwright/browser dependencies)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential gcc git curl libpq-dev \
        libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libx11-xcb1 libxcb1 \
        libxcomposite1 libxrandr2 libxdamage1 libxfixes3 libxrender1 \
        libxkbcommon0 libgbm1 libpango-1.0-0 libpangocairo-1.0-0 libasound2 \
        libxss1 libxtst6 \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20, pnpm and clean apt cache
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g pnpm \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip and packaging tools
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Install CPU-only PyTorch to prevent downloading giant CUDA-enabled packages (>2.5 GB)
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Copy backend dependencies
COPY pyproject.toml /app/
RUN sed '/llama-cpp-python/d' pyproject.toml > pyproject.tmp \
    && mv pyproject.tmp pyproject.toml \
    && pip install --no-cache-dir . \
    && python -m playwright install chromium

# Copy frontend dependency locks and install frontend dependencies
COPY web/package.json web/pnpm-lock.yaml* web/package-lock.json* /app/web/
WORKDIR /app/web
RUN pnpm install --frozen-lockfile || pnpm install

# Copy all repository files (excluding those in Dockerfile.local.dockerignore)
WORKDIR /app
COPY . /app

# Build the frontend next.js website, then prune devDependencies and clean store/caches
WORKDIR /app/web
RUN pnpm build \
    && pnpm prune --prod \
    && pnpm store prune \
    && npm cache clean --force

# Go back to /app
WORKDIR /app

# Make the startup script executable
RUN chmod +x /app/start.sh

# Expose ports for backend (8042) and frontend (8043)
EXPOSE 8042 8043

# Start backend and frontend
CMD ["/app/start.sh"]
